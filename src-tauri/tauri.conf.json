{
    "$schema":  "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName":  "maibook",
    "version":  "0.9.0",
    "identifier":  "com.maibook.app",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:5173",
                  "beforeDevCommand":  "pnpm dev",
                  "beforeBuildCommand":  "pnpm build"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Maibook",
                                    "width":  1200,
                                    "height":  800,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "minWidth":  800,
                                    "minHeight":  600
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "android":  {
                                   "debugApplicationIdSuffix":  ".debug"
                               },
                   "windows":  {
                                   "wix":  null,
                                   "nsis":  {
                                                "installMode":  "currentUser"
                                            }
                               }
               }
}
